# Admin panel kaliti — o'zingizning maxfiy kalitingizni kiriting
SIM_ADMIN_KEY=your-secret-admin-key

# Gmail SMTP sozlamalari
SIM_SMTP_HOST=smtp.gmail.com
SIM_SMTP_PORT=587
SIM_SMTP_USERNAME=youremail@gmail.com
# Gmail App Password (Google Account → Security → 2FA → App passwords)
SIM_SMTP_PASSWORD=your-app-password
SIM_SMTP_FROM=youremail@gmail.com
SIM_SMTP_USE_TLS=true
